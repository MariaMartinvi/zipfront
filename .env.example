# Copia a .env.local y rellena los valores.
# .env.local no se sube a Git.

# Backend (Render o local)
REACT_APP_API_URL=https://zipcd-backend-andand-gunicorn-app-app.onrender.com

# Blog en desarrollo: origen del servidor Astro (ej. http://localhost:4322) para mostrarlo dentro de la web
REACT_APP_BLOG_DEV_ORIGIN=http://localhost:4322

# Firebase (Consola Firebase → Configuración del proyecto)
REACT_APP_FIREBASE_API_KEY=
REACT_APP_FIREBASE_AUTH_DOMAIN=
REACT_APP_FIREBASE_PROJECT_ID=
REACT_APP_FIREBASE_STORAGE_BUCKET=
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=
REACT_APP_FIREBASE_APP_ID=
