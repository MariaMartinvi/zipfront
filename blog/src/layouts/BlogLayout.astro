---
import '../styles/chatsalsa.css';
import '../styles/header-footer.css';

interface Props {
  title: string;
  description: string;
  lang: 'es' | 'en';
  basePath: '' | '/en';
  canonical: string;
  image?: string;
}

const { title, description, lang, basePath, canonical, image } = Astro.props;
const site = 'https://chatsalsa.com';
const homeUrl = basePath || '/';
const blogUrl = basePath ? `${basePath}/blog` : '/blog';
const plansUrl = basePath ? `${basePath}/plans` : '/plans';
const faqUrl = basePath ? `${basePath}/faq` : '/faq';
const contactUrl = basePath ? `${basePath}/contact` : '/contact';
const termsUrl = basePath ? `${basePath}/terms` : '/terms';
const privacyUrl = basePath ? `${basePath}/privacy` : '/privacy';
const cookiesUrl = basePath ? `${basePath}/politica-cookies` : '/politica-cookies';
const ogImage = image ? (image.startsWith('http') ? image : `${site}${image}`) : `${site}/logo-chat.png`;
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <script is:inline>
      (function(){if(/[?&]embed=1/.test(window.location.search))document.documentElement.classList.add('blog-embed');})();
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="article" />
    <meta property="og:site_name" content="ChatSalsa" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <style is:inline>
      html.blog-embed .app-header,
      html.blog-embed .app-footer,
      html.blog-embed [data-embed-remove] { display: none !important; visibility: hidden !important; }
      html.blog-embed .blog-main { padding-top: 0.5rem; }
    </style>
  </head>
  <body>
    <header class="app-header" data-embed-remove>
      <div class="header-container">
        <a href={homeUrl} class="logo">
          <div class="logo-container">
            <div class="logo-icon">
              <svg xmlns="http://www.w3.org/2000/svg" class="logo-clipboard-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"></path>
              </svg>
            </div>
            <span class="logo-chatsalsa">ChatSalsa</span>
          </div>
        </a>
        <nav class="desktop-nav">
          <a href={homeUrl} class="nav-link">{lang === 'es' ? 'Inicio' : 'Home'}</a>
          <a href={blogUrl} class="nav-link">{lang === 'es' ? 'Blog' : 'Blog'}</a>
          <a href={plansUrl} class="nav-link">{lang === 'es' ? 'Precios' : 'Pricing'}</a>
          <a href={basePath ? '/login' : '/login'} class="nav-link">{lang === 'es' ? 'Iniciar sesión' : 'Log in'}</a>
          <a href={basePath ? '/register' : '/register'} class="nav-link sign-up">{lang === 'es' ? 'Prueba gratis' : 'Free trial'}</a>
          {basePath === '/en' ? (
            <a href="/blog" class="nav-link">ES</a>
          ) : (
            <a href="/en/blog" class="nav-link">EN</a>
          )}
        </nav>
      </div>
    </header>

    <main class="blog-main">
      <slot />
    </main>

    <footer class="app-footer" data-embed-remove>
      <div class="footer-content">
        <div class="footer-grid">
          <div class="footer-section">
            <h3>{lang === 'es' ? 'Navegación' : 'Navigation'}</h3>
            <div class="footer-links">
              <a href={homeUrl} class="footer-link">{lang === 'es' ? 'Inicio' : 'Home'}</a>
              <a href={blogUrl} class="footer-link">Blog</a>
              <a href={faqUrl} class="footer-link">{lang === 'es' ? 'FAQ' : 'FAQ'}</a>
              <a href={contactUrl} class="footer-link">{lang === 'es' ? 'Contacto' : 'Contact'}</a>
            </div>
          </div>
          <div class="footer-section">
            <h3>{lang === 'es' ? 'Legal' : 'Legal'}</h3>
            <div class="footer-links">
              <a href={termsUrl} class="footer-link">{lang === 'es' ? 'Términos' : 'Terms'}</a>
              <a href={privacyUrl} class="footer-link">{lang === 'es' ? 'Privacidad' : 'Privacy'}</a>
              <a href={cookiesUrl} class="footer-link">{lang === 'es' ? 'Cookies' : 'Cookies'}</a>
            </div>
          </div>
          <div class="footer-section">
            <h3>{lang === 'es' ? 'Descargas' : 'Downloads'}</h3>
            <div class="footer-links">
              <a
                href="https://play.google.com/store/apps/details?id=com.chatsalsa.app"
                class="footer-link"
                target="_blank"
                rel="noopener noreferrer"
                aria-label={lang === 'es' ? 'Descargar para Android' : 'Download for Android'}
              >
                <svg
                  class="footer-icon"
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                >
                  <path
                    d="M17.6 9.48l1.42-2.46a.5.5 0 0 0-.87-.5l-1.45 2.5A7.07 7.07 0 0 0 12 8a7.07 7.07 0 0 0-4.7 1.02L5.85 6.52a.5.5 0 1 0-.87.5l1.42 2.46A6.98 6.98 0 0 0 5 13v4.5A1.5 1.5 0 0 0 6.5 19h.75V22a1 1 0 0 0 1 1H10a1 1 0 0 0 1-1v-3h2v3a1 1 0 0 0 1 1h1.75a1 1 0 0 0 1-1v-3h.75A1.5 1.5 0 0 0 19 17.5V13a6.98 6.98 0 0 0-1.4-3.52zM9 6.25A1.25 1.25 0 1 1 7.75 5 1.25 1.25 0 0 1 9 6.25zm6 0A1.25 1.25 0 1 1 13.75 5 1.25 1.25 0 0 1 15 6.25z"
                  />
                </svg>
                <span>{lang === 'es' ? 'App Android' : 'Android App'}</span>
              </a>
            </div>
          </div>
        </div>
        <div class="footer-bottom">
          <p>&copy; {new Date().getFullYear()} ChatSalsa - {lang === 'es' ? 'Todos los derechos reservados' : 'All rights reserved'}</p>
          <button class="scroll-top" type="button" aria-label={lang === 'es' ? 'Volver arriba' : 'Back to top'}>
            &#8593;
          </button>
        </div>
      </div>
    </footer>
    <script is:inline>
      (function () {
        // Modo embed: ocultar header/footer y ajustar enlaces internos
        var isEmbed = window.location.search.indexOf('embed=1') !== -1;
        if (isEmbed) {
          function runEmbed() {
            document.querySelectorAll('[data-embed-remove]').forEach(function (el) { el.remove(); });
            document.querySelectorAll('a[href^="/blog"], a[href^="/en/blog"]').forEach(function (a) {
              try {
                var href = a.getAttribute('href');
                if (!href || href.indexOf('embed=1') !== -1) return;
                var url = new URL(href, window.location.origin);
                url.searchParams.set('embed', '1');
                a.setAttribute('href', url.pathname + url.search + (url.hash || ''));
              } catch (e) {}
            });
          }
          if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', runEmbed);
          } else {
            runEmbed();
          }
        }

        // Botón "volver arriba" del footer (igual comportamiento que en la web principal)
        function bindScrollTop() {
          var btn = document.querySelector('.scroll-top');
          if (!btn) return;
          btn.addEventListener('click', function () {
            window.scrollTo({ top: 0, behavior: 'smooth' });
          });
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', bindScrollTop);
        } else {
          bindScrollTop();
        }
      })();
    </script>
  </body>
</html>
