---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BlogLayout from '../../layouts/BlogLayout.astro';

const all = await getCollection('blog');
const posts = all
  .filter((e) => e.id.startsWith('es/') && !e.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

function slugFromId(id: string) {
  const parts = id.split('/');
  const name = parts[parts.length - 1] ?? id;
  return name.replace(/\.(mdx?|md)$/i, '');
}

const categories = Array.from(
  new Set(posts.map((p) => p.data.category).filter(Boolean) as string[]),
).sort((a, b) => a.localeCompare(b, 'es'));

const recentPosts: CollectionEntry<'blog'>[] = posts.slice(0, 4);
---

<BlogLayout
  title="Blog | ChatSalsa"
  description="Artículos sobre bienestar digital, psicología de la comunicación y cómo entender mejor tus chats."
  lang="es"
  basePath=""
  canonical="https://chatsalsa.com/blog"
>
  <section class="blog-page">
    <header class="blog-page-header">
      <p class="blog-kicker">Blog</p>
      <h1>Descubre nuevas formas de entender tus chats</h1>
      <p class="blog-subtitle">
        Consejos, ideas y reflexiones sobre comunicación digital, bienestar emocional y análisis de conversaciones.
      </p>
    </header>

    <div class="blog-layout">
      <div class="blog-main-column">
        <div class="blog-list">
          {posts.map((entry) => {
            const slug = slugFromId(entry.id);
            const hasImage = !!entry.data.featuredImage;
            return (
              <article class="blog-card">
                {hasImage && (
                  <a href={`/blog/${slug}`} class="blog-card-image-link">
                    <img
                      src={entry.data.featuredImage!}
                      alt={entry.data.title}
                      loading="lazy"
                      class="blog-card-image"
                    />
                  </a>
                )}
                <div class="blog-card-content">
                  <div class="blog-card-meta">
                    {entry.data.category && <span class="blog-card-category">{entry.data.category}</span>}
                    <span class="blog-card-date">
                      {entry.data.date.toLocaleDateString('es-ES', { day: '2-digit', month: 'long', year: 'numeric' })}
                    </span>
                  </div>
                  <a href={`/blog/${slug}`} class="blog-card-title-link">
                    <h2 class="blog-card-title">{entry.data.title}</h2>
                  </a>
                  {entry.data.excerpt && <p class="blog-card-excerpt">{entry.data.excerpt}</p>}
                  {entry.data.tags && entry.data.tags.length > 0 && (
                    <div class="blog-card-tags">
                      {entry.data.tags.map((tag) => (
                        <span class="blog-tag">{tag}</span>
                      ))}
                    </div>
                  )}
                </div>
              </article>
            );
          })}
        </div>
      </div>

      <aside class="blog-sidebar">
        <section class="blog-sidebar-section">
          <h3>Buscar</h3>
          <input
            type="search"
            class="blog-search-input"
            placeholder="Buscar en el blog..."
            aria-label="Buscar en el blog"
          />
          <p class="blog-search-hint">Próximamente: búsqueda por temas y palabras clave.</p>
        </section>

        {categories.length > 0 && (
          <section class="blog-sidebar-section">
            <h3>Categorías</h3>
            <ul class="blog-category-list">
              {categories.map((cat) => (
                <li>
                  <span class="blog-category-pill">{cat}</span>
                </li>
              ))}
            </ul>
          </section>
        )}

        {recentPosts.length > 0 && (
          <section class="blog-sidebar-section">
            <h3>Recientes</h3>
            <ul class="blog-recent-list">
              {recentPosts.map((entry) => {
                const slug = slugFromId(entry.id);
                return (
                  <li>
                    <a href={`/blog/${slug}`} class="blog-recent-link">
                      {entry.data.title}
                    </a>
                    <span class="blog-recent-date">
                      {entry.data.date.toLocaleDateString('es-ES', { day: '2-digit', month: 'short' })}
                    </span>
                  </li>
                );
              })}
            </ul>
          </section>
        )}
      </aside>
    </div>
  </section>
</BlogLayout>
